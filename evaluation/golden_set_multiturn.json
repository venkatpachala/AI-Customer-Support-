[
  {
    "id": "multiturn_damaged_photos_1",
    "turns": [
      {
        "message": "My order #12345 is damaged. I want to return it.",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": true,
          "must_not_contain": ["return label", "shipping address"]
        }
      },
      {
        "message": "I have uploaded the photos just now",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": false,
          "must_not_contain": ["what is your order id", "please provide your order id"]
        }
      }
    ]
  },
  {
    "id": "multiturn_order_id_then_return_1",
    "turns": [
      {
        "message": "I want to return my order",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": false,
          "must_not_contain": ["return label"]
        }
      },
      {
        "message": "Order id is 12345 and it is damaged",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": true,
          "must_not_contain": ["return label", "shipping address"]
        }
      }
    ]
  },
  {
    "id": "multiturn_high_value_1",
    "turns": [
      {
        "message": "I want a refund of 2500 for damaged order #12345",
        "expected": {
          "should_block": false,
          "should_escalate": true,
          "should_ask_for_photos": false,
          "must_not_contain": []
        }
      },
      {
        "message": "Please process it quickly",
        "expected": {
          "should_block": false,
          "should_escalate": true,
          "should_ask_for_photos": false,
          "must_not_contain": []
        }
      }
    ]
  },
  {
    "id": "multiturn_preference_1",
    "turns": [
      {
        "message": "I didn’t like the color of the product",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": false,
          "must_not_contain": ["return label"]
        }
      },
      {
        "message": "So can I return it?",
        "expected": {
          "should_block": false,
          "should_escalate": false,
          "should_ask_for_photos": false,
          "must_not_contain": ["return label", "shipping address"]
        }
      }
    ]
  }
]